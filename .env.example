# 應用程式
NODE_ENV=production
PORT=3000

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=transcriptions
# 本機開發用（Docker 內會由 docker-compose 覆寫）
DATABASE_URL=postgresql://app:secret@localhost:5432/transcriptions

# RabbitMQ（Docker 內會由 docker-compose 覆寫）
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# OpenAI
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1
OPENAI_CHAT_MODEL=gpt-4o-mini

# 上傳設定
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=100
