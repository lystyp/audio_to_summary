# 應用程式
NODE_ENV=prd
PORT=3000

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=transcriptions
# 本機開發用（Docker 內會由 docker-compose 覆寫）
DATABASE_URL=postgresql://app:secret@localhost:5432/transcriptions

# RabbitMQ（Docker 內會由 docker-compose 覆寫）
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Google Cloud Storage
GCS_BUCKET=your-gcs-bucket-name

# Google Gemini（LLM 摘要）
GEMINI_API_KEY=your-gemini-api-key

# Google STT 語言代碼（預設繁體中文）
STT_LANGUAGE_CODE=cmn-Hant-TW

# 上傳設定
MAX_FILE_SIZE_MB=100
